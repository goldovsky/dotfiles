{
  "name": "cobalt2",
  "description": "Cobalt2 theme for OpenCode - based on official Cobalt2 by Wes Bos",
  "colors": {
    "background":     "#122637",
    "foreground":     "#FFFFFF",
    "black":          "#000000",
    "red":            "#FF0000",
    "green":          "#37DD21",
    "yellow":         "#FEE409",
    "blue":           "#1460D2",
    "magenta":        "#FF005D",
    "cyan":           "#00BBBB",
    "white":          "#BBBBBB",
    "bright-black":   "#545454",
    "bright-red":     "#F40D17",
    "bright-green":   "#3BCF1D",
    "bright-yellow":  "#ECC809",
    "bright-blue":    "#5555FF",
    "bright-magenta": "#FF55FF",
    "bright-cyan":    "#6AE3F9",
    "bright-white":   "#FFFFFF",
    "dark-cell":      "#0A1A27",
    "medium-cell":    "#1A3A52",
    "light-cell":     "#FFFFFF",
    "opencode-defs": {
      "bg":           "#122637",
      "bgPanel":      "#0A1A27",
      "bgElement":    "#1A3A52",
      "fg":           "#FFFFFF",
      "fgMuted":      "#ADB7C9",
      "border":       "#2D5A7B",
      "borderActive": "#5555FF",
      "primary":      "#0088FF",
      "accent":       "#2AFFDF",
      "success":      "#9EFF80",
      "warning":      "#FFC600",
      "error":        "#FF0088",
      "info":         "#FF9D00",
      "comment":      "#0088FF",
      "keyword":      "#FF9D00",
      "string":       "#9EFF80",
      "variable":     "#FFFFFF",
      "type":         "#2AFFDF",
      "operator":     "#FF9D00",
      "punctuation":  "#FFFFFF",
      "constant":     "#FF628C",
      "number":       "#FFC600"
    },
    "opencode-theme": {
      "primary":                  { "dark": "primary", "light": "primary" },
      "secondary":                { "dark": "accent", "light": "accent" },
      "accent":                   { "dark": "accent", "light": "accent" },
      "error":                    { "dark": "error", "light": "error" },
      "warning":                  { "dark": "warning", "light": "warning" },
      "success":                  { "dark": "success", "light": "success" },
      "info":                     { "dark": "info", "light": "info" },
      "text":                     { "dark": "fg", "light": "fg" },
      "textMuted":                { "dark": "fgMuted", "light": "fgMuted" },
      "background":               { "dark": "bg", "light": "bg" },
      "backgroundPanel":          { "dark": "bgPanel", "light": "bgPanel" },
      "backgroundElement":        { "dark": "bgElement", "light": "bgElement" },
      "border":                   { "dark": "border", "light": "border" },
      "borderActive":             { "dark": "borderActive", "light": "borderActive" },
      "borderSubtle":             { "dark": "border", "light": "border" },
      "diffAdded":                { "dark": "success", "light": "success" },
      "diffRemoved":              { "dark": "error", "light": "error" },
      "diffContext":              { "dark": "fgMuted", "light": "fgMuted" },
      "diffHunkHeader":           { "dark": "border", "light": "border" },
      "diffHighlightAdded":       { "dark": "success", "light": "success" },
      "diffHighlightRemoved":     { "dark": "error", "light": "error" },
      "diffAddedBg":              { "dark": "#1A3A52", "light": "#1A3A52" },
      "diffRemovedBg":            { "dark": "#1A3A52", "light": "#1A3A52" },
      "diffContextBg":            { "dark": "bgPanel", "light": "bgPanel" },
      "diffLineNumber":           { "dark": "border", "light": "border" },
      "diffAddedLineNumberBg":    { "dark": "#1A3A52", "light": "#1A3A52" },
      "diffRemovedLineNumberBg":  { "dark": "#1A3A52", "light": "#1A3A52" },
      "markdownText":             { "dark": "fg", "light": "fg" },
      "markdownHeading":          { "dark": "warning", "light": "warning" },
      "markdownLink":             { "dark": "primary", "light": "primary" },
      "markdownLinkText":         { "dark": "accent", "light": "accent" },
      "markdownCode":             { "dark": "success", "light": "success" },
      "markdownBlockQuote":       { "dark": "fgMuted", "light": "fgMuted" },
      "markdownEmph":             { "dark": "keyword", "light": "keyword" },
      "markdownStrong":           { "dark": "constant", "light": "constant" },
      "markdownHorizontalRule":   { "dark": "border", "light": "border" },
      "markdownListItem":         { "dark": "primary", "light": "primary" },
      "markdownListEnumeration":  { "dark": "accent", "light": "accent" },
      "markdownImage":            { "dark": "primary", "light": "primary" },
      "markdownImageText":        { "dark": "accent", "light": "accent" },
      "markdownCodeBlock":        { "dark": "fg", "light": "fg" },
      "syntaxComment":            { "dark": "comment", "light": "comment" },
      "syntaxKeyword":            { "dark": "keyword", "light": "keyword" },
      "syntaxFunction":           { "dark": "accent", "light": "accent" },
      "syntaxVariable":           { "dark": "variable", "light": "variable" },
      "syntaxString":             { "dark": "string", "light": "string" },
      "syntaxNumber":             { "dark": "number", "light": "number" },
      "syntaxType":               { "dark": "type", "light": "type" },
      "syntaxOperator":           { "dark": "operator", "light": "operator" },
      "syntaxPunctuation":        { "dark": "punctuation", "light": "punctuation" }
    }
  }
}
