      "markdownCodeBlock":        { "dark": "fg", "light": "fg" },
      "syntaxComment":            { "dark": "comment", "light": "comment" },
      "syntaxKeyword":            { "dark": "keyword", "light": "keyword" },
      "syntaxFunction":           { "dark": "accent", "light": "accent" },
      "syntaxVariable":           { "dark": "variable", "light": "variable" },
      "syntaxString":             { "dark": "string", "light": "string" },
      "syntaxNumber":             { "dark": "number", "light": "number" },
      "syntaxType":               { "dark": "type", "light": "type" },
      "syntaxOperator":           { "dark": "operator", "light": "operator" },
      "syntaxPunctuation":        { "dark": "punctuation", "light": "punctuation" }
